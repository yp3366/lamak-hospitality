# ============================================
# LAMAK HOSPITALITY UNIT - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# In Netlify: go to Site Settings → Environment Variables and add these

# ── SUPABASE ─────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── JWT SECRET ───────────────────────────────
# Generate a strong random string (min 32 chars)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string-minimum-32-chars

# ── OPTIONAL: EMAIL (for password reset emails) ──
# Using Resend (free tier: 100 emails/day)
RESEND_API_KEY=re_your_resend_api_key

# ── OPTIONAL: FILE STORAGE ───────────────────
# Supabase Storage (already included in your Supabase plan)
# or Cloudinary for image uploads
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
